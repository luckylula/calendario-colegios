# Neon (Postgres) — en Vercel usar la URL "Pooled connection" (hostname con -pooler)
# Si conectas Neon desde el marketplace de Vercel, también puede llamarse POSTGRES_PRISMA_URL
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Logo de la aplicación (opcional). Por defecto usa /public/logo.svg
# NEXT_PUBLIC_LOGO_URL="/logo.png"

# Google Drive — carpeta padre oficina (subcarpetas = colegios)
# https://drive.google.com/drive/folders/0B3NBmVGQogB-cHZMTS1kcGZDTlU
GOOGLE_DRIVE_CARPETA_PADRE_OFICINA="0B3NBmVGQogB-cHZMTS1kcGZDTlU"

# Fase 2/3 — webhooks n8n (opcional en Fase 1)
N8N_BASE_URL="https://n8n.lulamartinezperez.com"
N8N_WEBHOOK_LEER_CALENDARIO="/webhook/leer-calendario-colegio"
N8N_WEBHOOK_GENERAR_CALENDARIO="/webhook/generar-y-subir-calendario"
N8N_WEBHOOK_TOKEN=""
